{
  "name": "openstrat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "pnpm -r --sort run build",
    "format:check": "prettier --check .",
    "ingest:hyperliquid": "pnpm --filter @openstrat/market-data ingest:hyperliquid --",
    "lint": "eslint .",
    "smoke:live:hyperliquid": "pnpm --filter @openstrat/market-data smoke:live:hyperliquid",
    "test": "vitest run",
    "typecheck": "pnpm -r --sort run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
