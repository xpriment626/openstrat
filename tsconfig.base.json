{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@openstrat/backtesting": ["./packages/backtesting/src/index.ts"],
      "@openstrat/domain": ["./packages/domain/src/index.ts"],
      "@openstrat/market-data": ["./packages/market-data/src/index.ts"],
      "@openstrat/persistence": ["./packages/persistence/src/index.ts"],
      "@openstrat/risk": ["./packages/risk/src/index.ts"],
      "@openstrat/strategy-sdk": ["./packages/strategy-sdk/src/index.ts"],
      "@openstrat/workers": ["./packages/workers/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true
  }
}
