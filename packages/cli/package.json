{
  "name": "openstrat",
  "version": "0.0.1-dev.0",
  "type": "module",
  "description": "Local-first OpenStrat CLI and gateway harness.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openstrat": "./dist/openstrat"
  },
  "files": [
    "dist/openstrat",
    "dist/index.js",
    "dist/**/*.d.ts",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1"
  },
  "devDependencies": {
    "esbuild": "latest"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
