{
  "name": "@openstrat/market-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ingest:hyperliquid": "node dist/cli/ingest-hyperliquid.js",
    "smoke:live:hyperliquid": "pnpm run build && node dist/hyperliquid/live-smoke.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openstrat/domain": "workspace:*",
    "@openstrat/persistence": "workspace:*",
    "zod": "latest"
  }
}
